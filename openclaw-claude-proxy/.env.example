# Server port
PORT=3456

# API key for authenticating incoming requests (set your own secret)
API_KEY=sk-openclaw-proxy-secret-change-me

# Claude Code CLI path (default: claude)
CLAUDE_CLI_PATH=claude

# Max concurrent requests (to avoid spawning too many CLI processes)
MAX_CONCURRENT=3

# Request timeout in milliseconds (5 minutes)
REQUEST_TIMEOUT=300000

# Claude CLI --max-turns：單次對話允許的工具執行輪數，預設 10
# 若常被「maxtool」限制擋住，可調高（例如 30、50），再重啟 Proxy
# MAX_TOOL_TURNS=10
MAX_TOOL_TURNS=50
